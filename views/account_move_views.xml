<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_vendor_bill_import_ec" model="ir.ui.view">
        <field name="name">account.move.form.vendor.bill.import.ec</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_post']" position="before">
                <button
                    name="action_open_vendor_bill_import_wizard"
                    type="object"
                    string="Import XML/PDF"
                    class="btn-secondary"
                    invisible="move_type not in ('in_invoice','in_refund') or state != 'draft'"
                />
            </xpath>
        </field>
    </record>
</odoo>
